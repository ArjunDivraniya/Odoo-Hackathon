  assignments AuditAssignment[]
  results     AuditResult[]

  @@index([companyId])
  @@index([isActive])
  @@index([nextAuditDate])
  @@index([startDate, endDate])
  @@map("audit_cycles")
}

/// Audit assignments linking auditors to audit cycles.
model AuditAssignment {
  id             String      @id @default(uuid()) @db.Uuid
  cycleId        String      @map("cycle_id") @db.Uuid
  auditorId      String      @map("auditor_id") @db.Uuid
  officeId       String?     @map("office_id") @db.Uuid
  departmentId   String?     @map("department_id") @db.Uuid
  status         AuditStatus @default(SCHEDULED)
  scheduledDate  DateTime    @map("scheduled_date")
  startedAt      DateTime?   @map("started_at")
  completedAt    DateTime?   @map("completed_at")
  assetCount     Int?        @map("asset_count")
  auditedCount   Int         @default(0) @map("audited_count")
  discrepancyCount Int       @default(0) @map("discrepancy_count")
  notes          String?     @db.Text
  metadata       Json?       @db.Json
  createdBy      String?     @map("created_by") @db.Uuid
  updatedBy      String?     @map("updated_by") @db.Uuid
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deletedAt      DateTime?   @map("deleted_at")

  // Relations
  cycle   AuditCycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [auditorId], references: [id], onDelete: Cascade)
  results AuditResult[]

  @@unique([cycleId, auditorId])
  @@index([cycleId])
  @@index([auditorId])
  @@index([status])
  @@index([scheduledDate])
  @@map("audit_assignments")
}

/// Individual audit findings per asset within a cycle.
model AuditResult {
  id               String      @id @default(uuid()) @db.Uuid
  assignmentId     String      @map("assignment_id") @db.Uuid
  cycleId          String      @map("cycle_id") @db.Uuid
  assetId          String      @map("asset_id") @db.Uuid
  status           String      @db.VarChar(30)
  condition        AssetCondition?
  locationMatch    Boolean?    @map("location_match")
  expectedLocation String?     @map("expected_location") @db.VarChar(300)
  actualLocation   String?     @map("actual_location") @db.VarChar(300)
  photos           Json?       @db.Json
  notes            String?     @db.Text
  auditedAt        DateTime    @default(now()) @map("audited_at")
  verifiedBy       String?     @map("verified_by") @db.Uuid
  verifiedAt       DateTime?   @map("verified_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  // Relations
  assignment   AuditAssignment  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  cycle        AuditCycle       @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  asset        Asset            @relation(fields: [assetId], references: [id], onDelete: Cascade)
  discrepancies AuditDiscrepancy[]

  @@unique([cycleId, assetId])
  @@index([assignmentId])
  @@index([cycleId])
  @@index([assetId])
  @@index([status])
  @@map("audit_results")
}

/// Discrepancies found during audits requiring resolution.
model AuditDiscrepancy {
  id              String        @id @default(uuid()) @db.Uuid
  resultId        String        @map("result_id") @db.Uuid
  discrepancyType String        @map("discrepancy_type") @db.VarChar(50)
  severity        PriorityLevel @default(MEDIUM)
  description     String        @db.Text
  expectedValue   Json?         @map("expected_value") @db.Json
  actualValue     Json?         @map("actual_value") @db.Json
  status          String        @default("OPEN") @db.VarChar(30)
  assignedTo      String?       @map("assigned_to") @db.Uuid
  resolution      String?       @db.Text
  resolvedAt      DateTime?     @map("resolved_at")
  resolvedBy      String?       @map("resolved_by") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Relations
  result AuditResult @relation(fields: [resultId], references: [id], onDelete: Cascade)

  @@index([resultId])
  @@index([status])
  @@index([severity])
  @@index([assignedTo])
  @@map("audit_discrepancies")
}

