// MODULE 15-26: ASSET MANAGEMENT
// ============================================================================

/// Hierarchical asset categorization (e.g., IT > Laptops > MacBooks).
model AssetCategory {
  id                   String               @id @default(uuid()) @db.Uuid
  companyId            String               @map("company_id") @db.Uuid
  parentId             String?              @map("parent_id") @db.Uuid
  name                 String               @db.VarChar(200)
  code                 String               @db.VarChar(20)
  description          String?              @db.Text
  icon                 String?              @db.VarChar(50)
  color                String?              @db.VarChar(7)
  depreciationMethod   String?              @map("depreciation_method") @db.VarChar(50)
  usefulLifeMonths     Int?                 @map("useful_life_months")
  salvageValuePercent  Decimal?         @map("salvage_value_percent") @db.Decimal(5, 2)
  requiresMaintenance  Boolean              @default(true) @map("requires_maintenance")
  requiresCalibration  Boolean              @default(false) @map("requires_calibration")
  isActive             Boolean              @default(true) @map("is_active")
  level                Int                  @default(0)
  sortOrder            Int                  @default(0) @map("sort_order")
  metadata             Json?                @db.Json
  createdBy            String?              @map("created_by") @db.Uuid
  updatedBy            String?              @map("updated_by") @db.Uuid
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  deletedAt            DateTime?            @map("deleted_at")

  // Relations
  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent        AssetCategory?       @relation("CategoryTree", fields: [parentId], references: [id])
  children      AssetCategory[]      @relation("CategoryTree")
  customFields  CategoryCustomField[]
  assets        Asset[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([parentId])
  @@index([name])
  @@map("asset_categories")
}

/// Custom field definitions per category for flexible asset metadata.
model CategoryCustomField {
  id            String   @id @default(uuid()) @db.Uuid
  categoryId    String   @map("category_id") @db.Uuid
  name          String   @db.VarChar(100)
  label         String   @db.VarChar(200)
  fieldType     String   @map("field_type") @db.VarChar(30)
  isRequired    Boolean  @default(false) @map("is_required")
  isSearchable  Boolean  @default(false) @map("is_searchable")
  isFilterable  Boolean  @default(false) @map("is_filterable")
  defaultValue  Json?    @map("default_value") @db.Json
  options       Json?    @db.Json
  validation    Json?    @db.Json
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  category AssetCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, name])
  @@index([categoryId])
  @@map("category_custom_fields")
}

/// Core asset record. The central entity of the entire system.
model Asset {
  id               String          @id @default(uuid()) @db.Uuid
  companyId        String          @map("company_id") @db.Uuid
  categoryId       String          @map("category_id") @db.Uuid
  officeId         String          @map("office_id") @db.Uuid
  buildingId       String?         @map("building_id") @db.Uuid
  floorId          String?         @map("floor_id") @db.Uuid
  locationId       String?         @map("location_id") @db.Uuid
  departmentId     String?         @map("department_id") @db.Uuid
  assignedTo       String?         @map("assigned_to") @db.Uuid
  custodianId      String?         @map("custodian_id") @db.Uuid
  assetTag         String          @unique @map("asset_tag") @db.VarChar(50)
  serialNumber     String?         @map("serial_number") @db.VarChar(100)
  name             String          @db.VarChar(200)
  description      String?         @db.Text
  status           AssetStatus     @default(AVAILABLE)
  condition        AssetCondition  @default(GOOD)
  purchaseDate     DateTime?       @map("purchase_date")
  purchasePrice    Decimal?      @map("purchase_price") @db.Decimal(15, 2)
  currentValue     Decimal?      @map("current_value") @db.Decimal(15, 2)
  warrantyExpiry   DateTime?       @map("warranty_expiry")
  expectedLifeYears Int?           @map("expected_life_years")
  manufacturer     String?         @db.VarChar(200)
  model            String?         @db.VarChar(100)
  barcode          String?         @unique @db.VarChar(100)
  rfidTag          String?         @unique @map("rfid_tag") @db.VarChar(100)
  qrCodeId         String?         @map("qr_code_id") @db.Uuid
  imageUrl         String?         @map("image_url") @db.VarChar(500)
  customAttributes Json?           @map("custom_attributes") @db.Json
  specifications   Json?           @db.Json
  depreciation     Json?           @db.Json
  metadata         Json?           @db.Json
  isActive         Boolean         @default(true) @map("is_active")
  createdBy        String?         @map("created_by") @db.Uuid
  updatedBy        String?         @map("updated_by") @db.Uuid
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  deletedAt        DateTime?       @map("deleted_at")

  // Relations
  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category            AssetCategory        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  office              Office               @relation(fields: [officeId], references: [id], onDelete: Restrict)
  building            Building?            @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  floor               Floor?               @relation(fields: [floorId], references: [id], onDelete: SetNull)
  location            Location?            @relation(fields: [locationId], references: [id], onDelete: SetNull)
  creator             User?                @relation("AssetCreator", fields: [createdBy], references: [id])
  updater             User?                @relation("AssetUpdater", fields: [updatedBy], references: [id])
  images              AssetImage[]
  documents           AssetDocument[]
  qrCode              AssetQrCode?
  statusHistory       AssetStatusHistory[]
  allocations         AssetAllocation[]
  returns             AssetReturn[]
  tags                AssetTag[]
  labels              AssetLabel[]
  maintenanceRequests MaintenanceRequest[]
  transferRequests    TransferRequest[]
  audits              AuditResult[]
  rfidTagRecord       FutureRfidTag?
  aiPredictions       AiPrediction[]
  sharedResource      SharedResource?

  @@index([companyId])
  @@index([categoryId])
  @@index([officeId])
  @@index([buildingId])
  @@index([floorId])
  @@index([locationId])
  @@index([departmentId])
  @@index([assignedTo])
  @@index([status])
  @@index([condition])
  @@index([createdAt])
  @@index([purchaseDate])
  @@map("assets")
}

/// Image attachments for assets.
model AssetImage {
  id         String    @id @default(uuid()) @db.Uuid
  assetId    String    @map("asset_id") @db.Uuid
  fileId     String?   @map("file_id") @db.Uuid
  imageUrl   String?   @map("image_url") @db.VarChar(500)
  imageType  String    @default("GENERAL") @map("image_type") @db.VarChar(50)
  caption    String?   @db.VarChar(255)
  isPrimary  Boolean   @default(false) @map("is_primary")
  sortOrder  Int       @default(0) @map("sort_order")
  takenAt    DateTime? @map("taken_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  // Relations
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([isPrimary])
  @@map("asset_images")
}

/// Document attachments for assets (invoices, warranty cards, manuals).
model AssetDocument {
  id           String   @id @default(uuid()) @db.Uuid
  assetId      String   @map("asset_id") @db.Uuid
  fileId       String?  @map("file_id") @db.Uuid
  fileUrl      String?  @map("file_url") @db.VarChar(500)
  fileName     String?  @map("file_name") @db.VarChar(255)
  fileSize     Int?     @map("file_size")
  mimeType     String?  @map("mime_type") @db.VarChar(100)
  documentType String   @map("document_type") @db.VarChar(50)
  title        String   @db.VarChar(200)
  description  String?  @db.Text
  expiryDate   DateTime? @map("expiry_date")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  // Relations
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([documentType])
  @@map("asset_documents")
}

/// QR code records for asset identification and quick-lookup.
model AssetQrCode {
  id           String    @id @default(uuid()) @db.Uuid
  assetId      String    @unique @map("asset_id") @db.Uuid
  code         String    @unique @db.VarChar(255)
  format       String    @default("QR_CODE") @db.VarChar(20)
  imageUrl     String?   @map("image_url") @db.VarChar(500)
  scanCount    Int       @default(0) @map("scan_count")
  lastScannedAt DateTime? @map("last_scanned_at")
  lastScannedBy String?  @map("last_scanned_by") @db.Uuid
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([isActive])
  @@map("asset_qr_codes")
}

/// Status change audit trail for every asset.
model AssetStatusHistory {
  id               String          @id @default(uuid()) @db.Uuid
  assetId          String          @map("asset_id") @db.Uuid
  previousStatus   AssetStatus?    @map("previous_status")
  newStatus        AssetStatus     @map("new_status")
  previousCondition AssetCondition? @map("previous_condition")
  newCondition     AssetCondition? @map("new_condition")
  reason           String?         @db.Text
  notes            String?         @db.Text
  changedBy        String?         @map("changed_by") @db.Uuid
  changedAt        DateTime        @default(now()) @map("changed_at")
  createdAt        DateTime        @default(now()) @map("created_at")

  // Relations
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([newStatus])
  @@index([changedAt])
  @@map("asset_status_history")
}

/// Asset allocation records tracking who has which asset.
model AssetAllocation {
  id                 String           @id @default(uuid()) @db.Uuid
  assetId            String           @map("asset_id") @db.Uuid
  employeeId         String           @map("employee_id") @db.Uuid
  allocatedBy        String           @map("allocated_by") @db.Uuid
  status             AllocationStatus @default(PENDING)
  allocationDate     DateTime         @default(now()) @map("allocation_date")
  expectedReturnDate DateTime?        @map("expected_return_date")
  actualReturnDate   DateTime?        @map("actual_return_date")
  returnCondition    AssetCondition?  @map("return_condition")
  returnNotes        String?          @map("return_notes") @db.Text
  returnVerifiedBy   String?          @map("return_verified_by") @db.Uuid
  purpose            String?          @db.Text
  approvalStatus     ApprovalStatus   @default(PENDING) @map("approval_status")
  approvedBy         String?          @map("approved_by") @db.Uuid
  approvedAt         DateTime?        @map("approved_at")
  rejectionReason    String?          @map("rejection_reason") @db.Text
  notes              String?          @db.Text
  metadata           Json?            @db.Json
  createdBy          String?          @map("created_by") @db.Uuid
  updatedBy          String?          @map("updated_by") @db.Uuid
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  deletedAt          DateTime?        @map("deleted_at")

  // Relations
  asset    Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user     User              @relation("AllocationUser", fields: [employeeId], references: [id], onDelete: Restrict)
  allocatedByUser User       @relation("AllocatedByUser", fields: [allocatedBy], references: [id], onDelete: Restrict)
  approver User?             @relation("ApprovedByAlloc", fields: [approvedBy], references: [id])
  history  AllocationHistory[]
  return   AssetReturn?

  @@index([assetId])
  @@index([employeeId])
  @@index([status])
  @@index([allocationDate])
  @@index([expectedReturnDate])
  @@index([approvalStatus])
  @@map("asset_allocations")
}

/// Historical log of allocation changes for audit purposes.
model AllocationHistory {
  id           String           @id @default(uuid()) @db.Uuid
  allocationId String           @map("allocation_id") @db.Uuid
  action       String           @db.VarChar(50)
  oldValues    Json?            @map("old_values") @db.Json
  newValues    Json?            @map("new_values") @db.Json
  performedBy  String?          @map("performed_by") @db.Uuid
  performedAt  DateTime         @default(now()) @map("performed_at")
  notes        String?          @db.Text
  ipAddress    String?          @map("ip_address") @db.VarChar(45)
  createdAt    DateTime         @default(now()) @map("created_at")

  // Relations
  allocation AssetAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)

  @@index([allocationId])
  @@index([performedAt])
  @@map("allocation_history")
}

/// Asset return records tracking when assets are returned.
model AssetReturn {
  id              String         @id @default(uuid()) @db.Uuid
  allocationId    String         @unique @map("allocation_id") @db.Uuid
  assetId         String         @map("asset_id") @db.Uuid
  returnedBy      String         @map("returned_by") @db.Uuid
  verifiedBy      String?        @map("verified_by") @db.Uuid
  returnDate      DateTime       @default(now()) @map("return_date")
  condition       AssetCondition
  damageReport    Json?          @map("damage_report") @db.Json
  missingItems    Json?          @map("missing_items") @db.Json
  notes           String?        @db.Text
  requiresRepair  Boolean        @default(false) @map("requires_repair")
  photos          Json?          @db.Json
  status          String         @default("PENDING") @db.VarChar(30)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Relations
  allocation AssetAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  asset      Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([returnDate])
  @@index([status])
  @@map("asset_returns")
}

/// Inter-office asset transfer requests.
model TransferRequest {
  id               String         @id @default(uuid()) @db.Uuid
  companyId        String         @map("company_id") @db.Uuid
  assetId          String         @map("asset_id") @db.Uuid
  fromOfficeId     String         @map("from_office_id") @db.Uuid
  toOfficeId       String         @map("to_office_id") @db.Uuid
  fromLocationId   String?        @map("from_location_id") @db.Uuid
  toLocationId     String?        @map("to_location_id") @db.Uuid
  requestedBy      String         @map("requested_by") @db.Uuid
  status           TransferStatus @default(REQUESTED)
  priority         PriorityLevel  @default(MEDIUM)
  reason           String?        @db.Text
  expectedDate     DateTime?      @map("expected_date")
  actualDate       DateTime?      @map("actual_date")
  approvedBy       String?        @map("approved_by") @db.Uuid
  approvedAt       DateTime?      @map("approved_at")
  receivedBy       String?        @map("received_by") @db.Uuid
  receivedAt       DateTime?      @map("received_at")
  shippingTracking String?        @map("shipping_tracking") @db.VarChar(100)
  shippingCarrier  String?        @map("shipping_carrier") @db.VarChar(50)
  shippingCost     Decimal?     @map("shipping_cost") @db.Decimal(10, 2)
  conditionBefore  AssetCondition? @map("condition_before")
  conditionAfter   AssetCondition? @map("condition_after")
  notes            String?        @db.Text
  metadata         Json?          @db.Json
  createdBy        String?        @map("created_by") @db.Uuid
  updatedBy        String?        @map("updated_by") @db.Uuid
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  deletedAt        DateTime?      @map("deleted_at")

  // Relations
  asset           Asset            @relation(fields: [assetId], references: [id], onDelete: Cascade)
  requestedByUser User             @relation("RequestedByTransfer", fields: [requestedBy], references: [id], onDelete: Restrict)
  approvedByUser  User?            @relation("ApprovedByTransfer", fields: [approvedBy], references: [id], onDelete: SetNull)
  receivedByUser  User?            @relation("ReceivedByTransfer", fields: [receivedBy], references: [id], onDelete: SetNull)
  history         TransferHistory[]

  @@index([companyId])
  @@index([assetId])
  @@index([requestedBy])
  @@index([status])
  @@index([fromOfficeId])
  @@index([toOfficeId])
  @@index([createdAt])
  @@map("transfer_requests")
}

/// Transfer status change history.
model TransferHistory {
  id          String         @id @default(uuid()) @db.Uuid
  transferId  String         @map("transfer_id") @db.Uuid
  action      String         @db.VarChar(50)
  oldValues   Json?          @db.Json
  newValues   Json?          @db.Json
  performedBy String?        @map("performed_by") @db.Uuid
  performedAt DateTime       @default(now()) @map("performed_at")
  notes       String?        @db.Text
  createdAt   DateTime       @default(now()) @map("created_at")

  // Relations
  transfer TransferRequest @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([transferId])
  @@index([performedAt])
  @@map("transfer_history")
}

// ============================================================================
// MODULE 27-30: SHARED RESOURCES & BOOKINGS
// ============================================================================

/// Bookable shared resources (meeting rooms, projectors, vehicles, etc.).
model SharedResource {
  id                      String    @id @default(uuid()) @db.Uuid
  companyId               String    @map("company_id") @db.Uuid
  assetId                 String?   @unique @map("asset_id") @db.Uuid
  name                    String    @db.VarChar(200)
  description             String?   @db.Text
  resourceType            String    @map("resource_type") @db.VarChar(50)
  capacity                Int       @default(1)
  officeId                String?   @map("office_id") @db.Uuid
  locationId              String?   @map("location_id") @db.Uuid
  isActive                Boolean   @default(true) @map("is_active")
  isBookable              Boolean   @default(true) @map("is_bookable")
  requiresApproval        Boolean   @default(false) @map("requires_approval")
  maxBookingDurationHours Int?      @map("max_booking_duration_hours")
  bookingRules            Json?     @map("booking_rules") @db.Json
  operatingHours          Json?     @map("operating_hours") @db.Json
  metadata                Json?     @db.Json
  createdBy               String?   @map("created_by") @db.Uuid
  updatedBy               String?   @map("updated_by") @db.Uuid
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  deletedAt               DateTime? @map("deleted_at")

  // Relations
  company  Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  asset    Asset?            @relation(fields: [assetId], references: [id], onDelete: SetNull)
  bookings ResourceBooking[]

  @@index([companyId])
  @@index([resourceType])
  @@index([officeId])
  @@index([isActive])
  @@map("shared_resources")
}

/// Resource booking records for shared resource scheduling.
model ResourceBooking {
  id             String        @id @default(uuid()) @db.Uuid
  resourceId     String        @map("resource_id") @db.Uuid
  bookedBy       String        @map("booked_by") @db.Uuid
  status         BookingStatus @default(PENDING)
  title          String        @db.VarChar(200)
  description    String?       @db.Text
  startTime      DateTime      @map("start_time")
  endTime        DateTime      @map("end_time")
  actualStart    DateTime?     @map("actual_start")
  actualEnd      DateTime?     @map("actual_end")
  recurrenceRule String?       @map("recurrence_rule") @db.VarChar(255)
  recurrenceEnd  DateTime?     @map("recurrence_end")
  isRecurring    Boolean       @default(false) @map("is_recurring")
  parentBookingId String?      @map("parent_booking_id") @db.Uuid
  attendeeCount  Int           @default(1) @map("attendee_count")
  notes          String?       @db.Text
  cancellationReason String?   @map("cancellation_reason") @db.Text
  cancelledAt    DateTime?     @map("cancelled_at")
  metadata       Json?         @db.Json
  createdBy      String?       @map("created_by") @db.Uuid
  updatedBy      String?       @map("updated_by") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  // Relations
  resource        SharedResource       @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  bookedByUser    User                 @relation("BookedByUser", fields: [bookedBy], references: [id], onDelete: Restrict)
  participants    BookingParticipant[]
  history         BookingHistory[]

  @@index([resourceId])
  @@index([bookedBy])
  @@index([status])
  @@index([startTime])
  @@index([endTime])
  @@index([resourceId, startTime, endTime])
  @@map("resource_bookings")
}

/// Participants in a resource booking.
model BookingParticipant {
  id          String    @id @default(uuid()) @db.Uuid
  bookingId   String    @map("booking_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  status      String    @default("INVITED") @db.VarChar(20)
  response    String?   @db.VarChar(20)
  isOrganizer Boolean   @default(false) @map("is_organizer")
  attended    Boolean?  @db.Boolean
  checkedInAt DateTime? @map("checked_in_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  booking ResourceBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([bookingId, userId])
  @@index([bookingId])
  @@index([userId])
