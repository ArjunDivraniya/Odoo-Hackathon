/// Maintenance request records for asset upkeep and repairs.
model MaintenanceRequest {
  id              String            @id @default(uuid()) @db.Uuid
  companyId       String            @map("company_id") @db.Uuid
  assetId         String            @map("asset_id") @db.Uuid
  requestedBy     String            @map("requested_by") @db.Uuid
  title           String            @db.VarChar(200)
  description     String            @db.Text
  status          MaintenanceStatus @default(REQUESTED)
  priority        PriorityLevel     @default(MEDIUM)
  type            String            @default("REPAIR") @db.VarChar(50)
  estimatedCost   Decimal?        @map("estimated_cost") @db.Decimal(12, 2)
  actualCost      Decimal?        @map("actual_cost") @db.Decimal(12, 2)
  approvedBy      String?           @map("approved_by") @db.Uuid
  approvedAt      DateTime?         @map("approved_at")
  rejectionReason String?           @map("rejection_reason") @db.Text
  scheduledDate   DateTime?         @map("scheduled_date")
  startedAt       DateTime?         @map("started_at")
  completedAt     DateTime?         @map("completed_at")
  verifiedBy      String?           @map("verified_by") @db.Uuid
  verifiedAt      DateTime?         @map("verified_at")
  verificationNotes String?         @map("verification_notes") @db.Text
  downtimeHours   Decimal?        @map("downtime_hours") @db.Decimal(8, 2)
  rootCause       String?           @map("root_cause") @db.Text
  resolution      String?           @db.Text
  vendorId        String?           @map("vendor_id") @db.Uuid
  externalRef     String?           @map("external_ref") @db.VarChar(100)
  notes           String?           @db.Text
  metadata        Json?             @db.Json
  createdBy       String?           @map("created_by") @db.Uuid
  updatedBy       String?           @map("updated_by") @db.Uuid
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")

  // Relations
  asset          Asset                    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  requestor      User                     @relation("RequestedByMaint", fields: [requestedBy], references: [id], onDelete: Restrict)
  approver       User?                    @relation("ApprovedByMaint", fields: [approvedBy], references: [id])
  verifier       User?                    @relation("VerifiedByMaint", fields: [verifiedBy], references: [id])
  attachments    MaintenanceAttachment[]
  statusHistory  MaintenanceStatusHistory[]
