  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([officeId, dayOfWeek, effectiveFrom])
  @@index([officeId])
  @@map("working_hours")
}

/// File storage tracking for uploaded files.
model FileStorage {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  uploadedBy   String   @map("uploaded_by") @db.Uuid
  originalName String   @map("original_name") @db.VarChar(255)
  fileName     String   @map("file_name") @db.VarChar(255)
  mimeType     String   @map("mime_type") @db.VarChar(100)
  fileSize     BigInt   @map("file_size")
  filePath     String   @map("file_path") @db.VarChar(500)
  storageType  String   @default("LOCAL") @map("storage_type") @db.VarChar(20)
  bucket       String?  @db.VarChar(100)
  checksum     String?  @db.VarChar(64)
  thumbnailPath String? @map("thumbnail_path") @db.VarChar(500)
  metadata     Json?    @db.Json
  isPublic     Boolean  @default(false) @map("is_public")
  accessCount  Int      @default(0) @map("access_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  // Relations
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([uploadedBy])
  @@index([mimeType])
  @@map("file_storages")
}

// ============================================================================
// MODULE 54-57: TAGS, LABELS & CUSTOM ATTRIBUTES
// ============================================================================

/// Reusable tags for flexible asset classification.
model Tag {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  name        String   @db.VarChar(100)
  color       String?  @db.VarChar(7)
  description String?  @db.Text
  usageCount  Int      @default(0) @map("usage_count")
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  company Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assets  AssetTag[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([name])
  @@map("tags")
}

/// Junction: Assets ↔ Tags (many-to-many).
model AssetTag {
  id        String   @id @default(uuid()) @db.Uuid
  assetId   String   @map("asset_id") @db.Uuid
  tagId     String   @map("tag_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([assetId, tagId])
  @@index([assetId])
  @@index([tagId])
  @@map("asset_tags")
}

/// Physical labels (QR/barcode/RFID) attached to assets.
model AssetLabel {
  id         String    @id @default(uuid()) @db.Uuid
  assetId    String    @map("asset_id") @db.Uuid
  labelType  String    @default("STANDARD") @map("label_type") @db.VarChar(50)
  templateId String?   @map("template_id") @db.Uuid
  content    Json      @db.Json
  printData  String?   @map("print_data") @db.Text
  printedAt  DateTime? @map("printed_at")
  printedBy  String?   @map("printed_by") @db.Uuid
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  // Relations
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("asset_labels")
}

/// Entity-agnostic custom attribute definitions.
model CustomAttribute {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  entityType   String   @map("entity_type") @db.VarChar(50)
  name         String   @db.VarChar(100)
  label        String   @db.VarChar(100)
  fieldType    String   @map("field_type") @db.VarChar(30)
  isRequired   Boolean  @default(false) @map("is_required")
  isFilterable Boolean  @default(false) @map("is_filterable")
  isSearchable Boolean  @default(false) @map("is_searchable")
  defaultValue Json?    @map("default_value") @db.Json
  options      Json?    @db.Json
  validation   Json?    @db.Json
  sortOrder    Int      @default(0) @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, entityType, name])
  @@index([companyId])
  @@index([entityType])
  @@map("custom_attributes")
}

