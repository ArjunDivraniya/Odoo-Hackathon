              "mode": "raw",
              "raw": "{\n  \"email\": \"priy.mavani.01@gmail.com\",\n  \"password\": \"Pass@12345\",\n  \"firstName\": \"Priy\",\n  \"lastName\": \"Mavani\"\n}",
              "options": {
                "raw": {
